# Snakefile for Pixelgen Proxiome data processed by nf-core/pixelator

include: "rules/singlecell_import.smk"
if config.pipeline == 'pixiome':
    aggregate = False
include: "rules/singlecell_rules_common.smk"

copy_complete = "copy.complete"
archive_result = ["archive_setup.complete"] if getattr(config, "archive", False) else []
include: "rules/singlecell_pixiome_import.smk"

if external:
    wreport_result = []
    xreport_result = []
    copy_complete = []
    archive_result = []


rule all:
    input:
        "pixelator/experiment-summary.html",
        expand("pixelator/{sample}.layout.pxl", sample=samples),
        expand("pixelator/analysis/{sample}.report.json", sample=samples),
        FASTQ_MANIFEST_PATH,
        "finalreport/metric_summary.xlsx",
        "finalreport/summaries/experiment-summary.html",
        wreport_result,
        xreport_result,
        copy_complete,
        archive_result
